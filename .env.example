# انسخ الملف إلى .env.local وضع القيم الخاصة ببيئتك المحلية فقط.
# لا تضع أي مفاتيح حقيقية أو روابط مشروع إنتاج داخل المستودع.

# الرابط العام للإنتاج المستخدم في روابط التأكيد الخارجية.
VITE_PUBLIC_APP_URL=https://your-app.example.com/

# بيانات مشروع Supabase الخاصة بالبيئة.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key
